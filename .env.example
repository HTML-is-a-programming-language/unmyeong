# ── Supabase ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Paddle (웹 결제용) ────────────────────────────────────
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=live_xxxx
NEXT_PUBLIC_PADDLE_ENV=production
PADDLE_API_KEY=your-paddle-api-key
PADDLE_WEBHOOK_SECRET=your-webhook-secret

# 크레딧 패키지별 Paddle Price ID
PADDLE_PRICE_5_CREDITS=pri_xxxx
PADDLE_PRICE_20_CREDITS=pri_xxxx
PADDLE_PRICE_50_CREDITS=pri_xxxx

# ── RevenueCat (앱 인앱결제용) ────────────────────────────
# RevenueCat 대시보드 > API Keys 에서 확인
NEXT_PUBLIC_REVENUECAT_ANDROID_KEY=goog_xxxx   # Android Public API Key
NEXT_PUBLIC_REVENUECAT_IOS_KEY=appl_xxxx       # iOS Public API Key

# ── 앱 URL ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://un-myeong.com

# ── AI API ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxx
